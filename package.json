{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "examples/*"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "version": "pnpm install && git add pnpm-lock.yaml",
    "preinstall": "npx only-allow pnpm",
    "release:version": "pnpm run ci && lerna version --force-publish",
    "release:publish": "lerna publish from-git --yes --no-verify-access",
    "ci": "npm-run-all format:validate ci:subpackages",
    "compile": "turbo run clean && tsc --build",
    "compile:watch": "turbo run clean && tsc --build --watch",
    "ci:subpackages": "turbo run ci",
    "format:fix": "prettier --experimental-cli --write \"**/*.{ts,js,cjs,mjs,json,md,yml,yaml,css,html}\"",
    "format:validate": "prettier --experimental-cli --check \"**/*.{ts,js,cjs,mjs,json,md,yml,yaml,css,html}\"",
    "prepare": "husky"
  },
  "prettier": {
    "endOfLine": "lf"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs,json,md,yml,yaml,css,html}": [
      "prettier --experimental-cli --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.35",
    "c8": "11.0.0",
    "chai": "6.2.2",
    "cz-conventional-changelog": "3.3.0",
    "fs-extra": "11.3.4",
    "husky": "9.1.7",
    "lerna": "9.0.5",
    "lint-staged": "16.3.2",
    "mocha": "11.7.5",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "shx": "0.4.0",
    "source-map-support": "0.5.21",
    "typescript": "5.9.3",
    "turbo": "2.8.16"
  }
}
